# Paste your Anthropic API key here. Get one at https://console.anthropic.com/
# If you ever leak this key (screenshots, transcripts, commits) — rotate it immediately.
ANTHROPIC_API_KEY=sk-ant-...

# Default model. Haiku 4.5 is the recommended sweet spot — cheap, fast, reliable.
# Try claude-sonnet-4-6 for more visually ambitious Manim animations at ~3x cost.
PAPER2VIDEO_MODEL=claude-haiku-4-5-20251001

PAPER2VIDEO_OUT_DIR=./out

# --- Telegram Review Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- YouTube OAuth (get from Google Cloud Console) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- TikTok (get from TikTok Developer Portal) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Instagram (get from Meta Developer Portal) ---
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
PAPER2VIDEO_INSTAGRAM_USER_ID=
